# InvToolkit Environment Variables
# Copy to .env and fill in your values

# FMP API key (get from financialmodelingprep.com)
FMP_API_KEY=

# SEC EDGAR requires contact email in User-Agent header
EDGAR_USER_AGENT=InvToolkit your-email@example.com

# Data directory override (optional — defaults to Google Drive auto-detect)
# INVTOOLKIT_DATA_DIR=/path/to/your/data
